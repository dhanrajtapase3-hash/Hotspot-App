<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:background="#111c2a"
    android:padding="12dp" android:layout_marginBottom="6dp" android:gravity="center_vertical">
    <TextView android:id="@+id/deviceIcon" android:layout_width="40dp"
        android:layout_height="40dp" android:text="X" android:textSize="22sp" android:gravity="center"/>
    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="10dp">
        <TextView android:id="@+id/deviceName" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Device"
            android:textColor="#d0e0f0" android:textSize="13sp" android:textStyle="bold"/>
        <TextView android:id="@+id/deviceIp" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="192.168.43.x"
            android:textColor="#3a5568" android:textSize="10sp"/>
        <TextView android:id="@+id/deviceUsage" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="0 MB used"
            android:textColor="#00e5a0" android:textSize="11sp"/>
        <ProgressBar android:id="@+id/deviceProgress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="3dp"
            android:layout_marginTop="4dp" android:progressTint="#00e5a0"
            android:progressBackgroundTint="#1e2d3d" android:max="100"/>
    </LinearLayout>
    <Button android:id="@+id/blockBtn" android:layout_width="wrap_content"
        android:layout_height="wrap_content" android:text="Block"
        android:textSize="10sp" android:backgroundTint="#1e2d3d"
        android:textColor="#ff4d6d" android:padding="6dp"/>
</LinearLayout>